# Brevo (existing)
BREVO_API_KEY=
BREVO_LIST_ID=

# Admin dashboard
ADMIN_KEY=

# Goracash callback API
# Request credentials from your Goracash account > API et Authentification.
# GORACASH_CALLER must be your dedicated Goracash number in international
# format, e.g. 01 75 75 45 82 → 0033175754582
GORACASH_CLIENT_ID=
GORACASH_CLIENT_SECRET=
GORACASH_CALLER=

# BargesTech (TUNE/HasOffers) affiliate network — Keen + Kasamba
# Copy the per-offer tracking link verbatim from the BargesTech backoffice
# (Offers → <offer> → Tracking Link). Should look like:
#   https://bargestech.go2cloud.org/aff_c?offer_id=XXX&aff_id=YYY
# Do NOT pre-append aff_sub2 — the redirect handler stamps it at click time.
KEEN_CLICK_URL=
KASAMBA_CLICK_URL=

# Shared secret for the inbound BargesTech → /api/postback handshake.
# Generate a random 32+ char string (e.g. `openssl rand -hex 32`) and paste
# the same value into the BargesTech postback URL: ?secret=<this>
BARGESTECH_POSTBACK_SECRET=

# (Optional, v2) BargesTech Affiliate API credentials — not required for v1
# postback flow. Used later for conversion reconciliation via Affiliate_Report.
# BARGESTECH_NETWORK_ID=
# BARGESTECH_API_KEY=
