# Brevo (existing)
BREVO_API_KEY=
BREVO_LIST_ID=

# Admin dashboard
ADMIN_KEY=

# Discord webhook for real-time event notifications.
# Used to push click-out + conversion + OCI events into a Discord channel
# during the early-campaign phase, replacing the need for paid Vercel log
# retention. Free, easy setup:
#   1. Discord → server settings → Integrations → Webhooks → New Webhook
#   2. Pick a channel, copy the webhook URL, paste below + into Vercel env
# Leave blank to disable (graceful no-op).
DISCORD_WEBHOOK_URL=

# Goracash callback API
# Request credentials from your Goracash account > API et Authentification.
# GORACASH_CALLER must be your dedicated Goracash number in international
# format, e.g. 01 75 75 45 82 → 0033175754582
GORACASH_CLIENT_ID=
GORACASH_CLIENT_SECRET=
GORACASH_CALLER=

# BargesTech (TUNE/HasOffers) affiliate network — Keen + Kasamba
# Copy the per-offer tracking link verbatim from the BargesTech backoffice
# (Offers → <offer> → Tracking Link). Should look like:
#   https://bargestech.go2cloud.org/aff_c?offer_id=XXX&aff_id=YYY
# Do NOT pre-append aff_sub2 — the redirect handler stamps it at click time.
KEEN_CLICK_URL=
KASAMBA_CLICK_URL=

# Shared secret for the inbound BargesTech → /api/postback handshake.
# Generate a random 32+ char string (e.g. `openssl rand -hex 32`) and paste
# the same value into the BargesTech postback URL: ?secret=<this>
#
# Full BargesTech postback URL template (paste into Pixels & Postbacks → URL Postback):
#   https://www.voyantlove.fr/api/postback
#     ?secret=<BARGESTECH_POSTBACK_SECRET>
#     &txid={transaction_id}&event={event_id}&offer={offer_id}
#     &goal={goal_id}&goal_name={goal_name}&payout={payout}
#     &gclid={aff_sub2}&gbraid={aff_sub3}&wbraid={aff_sub4}
#     &country={country_code}&status={status}&dt={datetime}
#
# Sub-ID slot mapping is fixed:
#   aff_sub2 = gclid (standard web), aff_sub3 = gbraid (iOS ATT-restricted),
#   aff_sub4 = wbraid (web ITP-restricted). Exactly one is set per click.
BARGESTECH_POSTBACK_SECRET=

# (Optional, v2) BargesTech Affiliate API credentials — not required for v1
# postback flow. Used later for conversion reconciliation via Affiliate_Report.
# BARGESTECH_NETWORK_ID=
# BARGESTECH_API_KEY=

# Google Ads Click Conversion Import (OCI)
# Closes the loop: BargesTech postback → /api/postback → Google Ads receives
# the offline conversion attributed to the gclid. Google Ads Smart Bidding
# learns from real revenue, not proxy events.
#
# Setup (one-time, see README or ask Claude for the walkthrough):
#  1. Google Ads → Tools → Conversions → New conversion action →
#     Import → Other data sources → Track conversions from clicks
#     (Conversion source: API. Category: Purchase. Value: per-conversion $50.)
#     Save the Conversion Action ID from the URL after creation.
#  2. Apply for a developer token: https://ads.google.com/aw/apicenter
#  3. Create OAuth client (Desktop type) in Google Cloud Console under the
#     same Google account. Download client_id + client_secret.
#  4. Generate a refresh token via the Google OAuth Playground (one-time).
#  5. Customer ID is the 123-456-7890 in the top right of Google Ads.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Only needed if your account is under an MCC (manager account); otherwise
# leave blank and we default to GOOGLE_ADS_CUSTOMER_ID.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CONVERSION_ACTION_ID=
# Optional override if Google deprecates the default API version before we
# ship a code update.
# GOOGLE_ADS_API_VERSION=v18
